[Unit]
Description=AppLeap RAG FastAPI Server
After=network.target postgresql.service ollama.service
Wants=ollama.service

[Service]
Type=simple
User=abhinav
WorkingDirectory=/home/abhinav/appleap-rag/appleap-rag
ExecStart=/home/abhinav/.local/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
Environment=PYTHONPATH=/home/abhinav/appleap-rag/appleap-rag

[Install]
WantedBy=multi-user.target
